# Polyventure example environment for the current Kalshi pilot.
# Copy to .env locally and replace placeholder values before authenticated runs.
# KALSHI_ENV / KALSHI_OPERATION_LANE — RETIRED. The Kalshi environment (demo/prod) and the
# operation lane (sandbox/live/offline) are derived from the lane the operator selects at
# runtime; they are no longer read from this file. The web shell boots offline until a lane
# is selected. (CLI batch commands retain their sandbox default.)
KALSHI_API_KEY_ID=replace-with-demo-key-id
KALSHI_SANDBOX_API_KEY_ID=replace-with-sandbox-key-id
KALSHI_LIVE_API_KEY_ID=replace-with-live-key-id
KALSHI_PRIVATE_KEY_FILE=secrets/kalshi/demo/private_key.pem
KALSHI_SANDBOX_PRIVATE_KEY_FILE=secrets/kalshi/demo/private_key.pem
KALSHI_LIVE_PRIVATE_KEY_FILE=secrets/kalshi/live/private_key.pem
# KALSHI_API_BASE_URL — DEPRECATED. REST API base URL is now derived from KALSHI_SANDBOX_WEBSOCKET_URL / KALSHI_LIVE_WEBSOCKET_URL. This variable is no longer required and has no effect on lane routing.
KALSHI_WEBSOCKET_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
KALSHI_SANDBOX_WEBSOCKET_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
KALSHI_LIVE_WEBSOCKET_URL=wss://ws-api.kalshi.com/trade-api/ws/v2
KALSHI_SUBACCOUNT=0
KALSHI_SCAN_INTERVAL_MS=2000
KALSHI_ENTRY_WINDOW_START_SEC=900
KALSHI_ENTRY_WINDOW_END_SEC=60
KALSHI_MIN_EDGE_DOLLARS=0.03
KALSHI_FEE_RESERVE_DOLLARS=0.02
KALSHI_MIN_PROFIT_DOLLARS=0.01
KALSHI_MAX_PAIR_CONTRACTS=10
KALSHI_MAX_OPEN_PAIRS=20
KALSHI_MAX_UNHEDGED_SEC=5
KALSHI_POST_SUBMIT_PROCESSING_BUFFER_SEC=180
KALSHI_CANCEL_ON_PAUSE=true
KALSHI_LOG_LEVEL=INFO
KALSHI_STATE_DB_PATH=var/kalshi.sqlite3
